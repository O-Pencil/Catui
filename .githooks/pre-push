#!/bin/sh
#
# Pre-push workflow gate. Runs the fast, build-independent gates from
# .dev-docs/feature-workflow.md §5 before code leaves the machine, so structural
# violations (missing DIP headers, dependency cycles, package-boundary breaks,
# type errors) are caught here instead of going red on main after a direct push.
#
# Wired via `core.hooksPath=.githooks` (set by the `prepare` npm script on
# `npm install`). Build-dependent checks (verify:package-boundary:dist, tests)
# stay in CI. Bypass with `git push --no-verify` (discouraged).
#
set -e

echo "→ pre-push: running workflow gates (verify:all = dip + quality + package-boundary + tsc)…"

if ! npm run --silent verify:all; then
	echo ""
	echo "✗ pre-push blocked: workflow gates failed (see above)."
	echo "  Fix the violation, or bypass with: git push --no-verify  (discouraged)"
	exit 1
fi

echo "✓ pre-push: workflow gates passed."
